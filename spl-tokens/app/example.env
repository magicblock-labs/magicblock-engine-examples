# Copy this file to `.env` (in the same `app/` directory) and adjust values.
# CRA only reads variables prefixed with REACT_APP_ at build/start time —
# restart `yarn dev` after editing.

# --- Ephemeral Rollup endpoint (required for Setup to work) ---
# Without this, the app falls back to https://devnet.magicblock.app, which
# does not respond to getIdentity, so validator.current stays undefined and
# clicking Setup does nothing (silent retry loop).
REACT_APP_EPHEMERAL_PROVIDER_ENDPOINT=https://devnet-as.magicblock.app

# --- Optional: reuse an existing test mint instead of creating one ---
# When set, the app skips mint creation in Setup and reads balances against
# this mint. Must be a valid base58 pubkey of an SPL mint owned by the
# Token Program on the base layer.
# REACT_APP_SETUP_MINT=

# --- Optional: pre-funded queue payer keypair (path or URL) ---
# Path served by `public/` or a URL returning JSON-array keypair bytes.
# Used by handleSetupQueue() so the queue payer is stable across sessions
# instead of regenerated each load.
# REACT_APP_SETUP_QUEUE_KEYPAIR=/queue-keypair.json

# --- Optional: queue payer keypair inline as JSON array ---
# Alternative to the path-based variant above. Same shape as
# `solana-keygen new` output (a JSON array of 64 bytes).
# SETUP_QUEUE_KEYPAIR_JSON=[12,34,...]
