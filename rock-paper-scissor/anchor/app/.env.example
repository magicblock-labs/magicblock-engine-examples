# All values are optional — defaults target devnet + the public MagicBlock TEE.
# Program id. Defaults to the address baked into src/idl/anchor_rock_paper_scissor.json
# (kept in sync with `anchor build` via the sync-idl script).
# VITE_PROGRAM_ID=

# Solana base layer RPC
# VITE_BASE_ENDPOINT=https://rpc.magicblock.app/devnet

# MagicBlock TEE ephemeral rollup endpoints
# VITE_TEE_ENDPOINT=https://devnet-tee.magicblock.app
# VITE_TEE_WS_ENDPOINT=wss://devnet-tee.magicblock.app

# ER validator identity the PDAs get delegated to
# VITE_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Endpoint the wallet top-up signs/submits through. Defaults to devnet — the
# connected wallet derives its target chain from this URL.
# VITE_TOPUP_ENDPOINT=https://rpc.magicblock.app/devnet

# --- Local cluster (yarn setup in ../) ---
# VITE_BASE_ENDPOINT=http://localhost:8899
# VITE_TEE_ENDPOINT=http://localhost:6699
# VITE_TEE_WS_ENDPOINT=ws://localhost:6700
# VITE_VALIDATOR=mAGicPQYBMvcYveUZA5F5UNNwyHvfYh5xkLS2Fr1mev
